{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "Scheduler": {
    "StartTime": "7:10:00",
    "EndTime": "17:48:00",
    "Days": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
      "Sunday"
    ],
    "Holidays": []
  },
  "Ingestion": {
    "BaseUrl": "",
    "Authorization": "",
    "DepartmentIds": []
  },
  "Processing": {
    "Sla": "00:10:00",
    "NearBreachThreshold": 0.75,
    "AssignorDepartmentsFilter": []
  },
  "Notification": {
    "WebhookUrl": "",
    "EventUrlFormat": ""
  }
}